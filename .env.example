# NorskSikhi Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to GitHub

# ─── ANTHROPIC AI TUTOR ──────────────────────────────────────────────────────
# Get your API key from: https://console.anthropic.com/
# For production: use a backend proxy (see README) — never expose this in frontend
REACT_APP_ANTHROPIC_KEY=your_anthropic_api_key_here

# ─── UNSPLASH (Free image API for visual lessons) ────────────────────────────
# Get free API key from: https://unsplash.com/developers
# Free tier: 50 requests/hour — more than enough
REACT_APP_UNSPLASH_KEY=your_unsplash_api_key_here

# ─── APP CONFIG ──────────────────────────────────────────────────────────────
REACT_APP_APP_NAME=NorskSikhi
REACT_APP_VERSION=1.0.0
